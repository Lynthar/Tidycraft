# Auto-detect text files and normalize line endings to LF in the repo
* text=auto eol=lf

# Source code — always LF
*.rs        text eol=lf
*.ts        text eol=lf
*.tsx       text eol=lf
*.js        text eol=lf
*.jsx       text eol=lf
*.json      text eol=lf
*.toml      text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.html      text eol=lf
*.css       text eol=lf
*.md        text eol=lf
*.lock      text eol=lf
.gitignore  text eol=lf
.gitattributes text eol=lf

# Windows-specific scripts — keep CRLF
*.bat       text eol=crlf
*.cmd       text eol=crlf
*.ps1       text eol=crlf

# Binary assets — never convert
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.icns      binary
*.pdf       binary
